{
  "name": "harmonica-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "start": "bun run server/src/index.ts",
    "dev": "concurrently -n server,ui -c blue,magenta \"bun run dev:server --config-dir /tmp/.harmonica --workspace.repo_url=git@github.com:adamveld12/harmonica.git\" \"bun run dev:ui\"",
    "dev:server": "bun --watch run server/src/index.ts --debug --server.host localhost --server.port 6543 --workflows ./.agents/workflows",
    "dev:ui": "pnpm --filter harmonica-ui dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint 'server/src/**/*.ts' 'ui/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'server/src/**/*.ts' 'ui/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'server/src/**/*.ts' 'ui/src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'server/src/**/*.ts' 'ui/src/**/*.{ts,tsx,css}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "latest",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.50.0"
  }
}
